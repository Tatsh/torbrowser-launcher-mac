{
  "contributors": ["Andrew Udvare <audvare@gmail.com>"],
  "cspell": {
    "cache": {
      "useCache": true
    },
    "dictionaryDefinitions": [
      {
        "name": "main",
        "path": ".vscode/dictionary.txt"
      }
    ],
    "enableFileTypes": {
      "*": true
    },
    "enableGlobDot": true,
    "files": ["*"],
    "ignorePaths": [
      "*.1",
      "*.har",
      "*.lock",
      ".git/**",
      ".yarn/**/*.cjs",
      ".vscode/extensions.json",
      "dist/**",
      "man/**",
      "*.pbxproj",
      "*.xc*",
      "*.xib",
      ".yarn/**/*.cjs"
    ],
    "language": "en-GB",
    "languageSettings": [
      {
        "dictionaries": ["main"],
        "languageId": "*"
      }
    ],
    "useGitignore": true
  },
  "description": "Tor Browser Launcher for macOS, inspired by the Linux version.",
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "cspell": "^9.8.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ini": "^1.3.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-toml": "^2.0.6"
  },
  "files": ["LICENSE.txt", "README.md"],
  "homepage": "https://tatsh.github.io/torbrowser-launcher-mac/",
  "keywords": ["macos", "package manager", "tor"],
  "license": "MIT",
  "markdownlint-cli2": {
    "config": {
      "MD024": {
        "siblings_only": true
      },
      "MD033": {
        "allowed_elements": ["kbd"]
      },
      "default": true,
      "line-length": {
        "code_blocks": false,
        "line_length": 100,
        "tables": false
      }
    },
    "gitignore": true,
    "globs": ["**/*.md", "**/*.mdc"],
    "noBanner": true,
    "showFound": true
  },
  "name": "torbrowser-launcher-mac",
  "packageManager": "yarn@4.13.0",
  "prettier": {
    "endOfLine": "lf",
    "iniSpaceAroundEquals": true,
    "jsonRecursiveSort": true,
    "overrides": [
      {
        "files": ["package.json"],
        "options": {
          "parser": "json"
        }
      },
      {
        "files": ["*.json.dist"],
        "options": {
          "parser": "json"
        }
      },
      {
        "files": ["*.md", "*.mdc"],
        "options": {
          "parser": "markdown"
        }
      },
      {
        "files": [".swift-format"],
        "options": {
          "parser": "json"
        }
      },
      {
        "files": ["*.plist", "*.plist.in"],
        "options": {
          "parser": "xml"
        }
      }
    ],
    "plugins": [
      "@prettier/plugin-xml",
      "prettier-plugin-ini",
      "prettier-plugin-sort-json",
      "prettier-plugin-toml"
    ],
    "printWidth": 100,
    "reorderKeys": true,
    "singleQuote": true
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Tatsh/torbrowser-launcher-mac.git"
  },
  "scripts": {
    "build": "cmake --preset=default && cmake --build build",
    "check-formatting": "swift-format lint -r . && prettier -c . && markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2 '**/*.md' '#node_modules'",
    "check-spelling": "cspell --no-progress './**/*'  './**/.*'",
    "dict:update": "rm -f .vscode/dictionary.txt && cspell --no-progress './**/*' './**/.*' 2>&1 | grep -oP '(?<=Unknown word \\()\\S+(?=\\))' | python3 -c \"import sys; print('\\n'.join(sorted(set(l.strip().lower() for l in sys.stdin if l.strip()))))\" > .vscode/dictionary.txt",
    "format": "swift-format -i -r . && prettier -w . && markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "qa": "yarn check-spelling && yarn check-formatting"
  },
  "version": "0.1.0"
}
